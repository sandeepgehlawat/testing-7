# ============================================
# ChainTax Environment Variables
# ============================================
# Copy this file to .env.local and fill in your values

# Blockchain APIs
# ----------------
# Alchemy - All chains (EVM + Solana)
# Supports: Ethereum, Polygon, Arbitrum, Base, Optimism, Solana
# Get your key at: https://alchemy.com
ALCHEMY_API_KEY=

# CoinGecko - Historical prices (optional, increases rate limits)
# Get your key at: https://coingecko.com/api
COINGECKO_API_KEY=

# Authentication (Auth.js v5)
# ---------------------------
# Generate with: openssl rand -base64 32
AUTH_SECRET=

# Google OAuth
# Get credentials at: https://console.cloud.google.com/apis/credentials
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# GitHub OAuth
# Get credentials at: https://github.com/settings/developers
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# Optional: Next.js
# -----------------
# NEXTAUTH_URL=http://localhost:3000
